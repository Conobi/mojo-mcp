{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "mojo-mcp",
  "description": "Mojo language support for Claude Code — LSP integration for go-to-definition, hover, and diagnostics in .mojo files",
  "owner": {
    "name": "Conobi",
    "url": "https://github.com/Conobi/mojo-mcp"
  },
  "plugins": [
    {
      "name": "mojo-lsp",
      "description": "Mojo language server integration. Provides go-to-definition, find-references, hover, and diagnostics in .mojo files via the mojo lsp command (installed through mojo-compiler).",
      "version": "1.0.0",
      "author": {
        "name": "Conobi",
        "url": "https://github.com/Conobi"
      },
      "homepage": "https://github.com/Conobi/mojo-mcp",
      "repository": "https://github.com/Conobi/mojo-mcp",
      "license": "MIT",
      "source": "./plugins/mojo-lsp",
      "category": "development",
      "keywords": ["mojo", "lsp", "language-server", "modular"],
      "strict": false,
      "lspServers": {
        "mojo": {
          "command": "uvx",
          "args": ["--from", "mojo-compiler", "mojo", "lsp"],
          "extensionToLanguage": {
            ".mojo": "mojo"
          }
        }
      }
    }
  ]
}
